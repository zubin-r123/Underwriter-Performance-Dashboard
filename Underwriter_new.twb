      <aliases enabled='yes' />
      <column datatype='date' name='[Application Date]' role='dimension' type='ordinal' />
      <column datatype='string' name='[Application Id]' role='dimension' type='nominal' />
      <column datatype='real' name='[Approval Rate]' role='measure' type='quantitative' />
      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_544372654706106368] / TOTAL([Calculation_544372654706106368])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='No. Applications' datatype='integer' name='[Calculation_544372654706106368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Application Id])' />
      </column>
      <column caption='funnel for rank' datatype='integer' name='[Calculation_544372654718472193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Application Id]) * &#13;&#10;CASE [Calculation_544372654718648322]&#13;&#10;    WHEN 1 THEN 100&#13;&#10;    WHEN 2 THEN 80&#13;&#10;    WHEN 3 THEN 60&#13;&#10;    WHEN 4 THEN 40&#13;&#10;    WHEN 5 THEN 20&#13;&#10;    WHEN 6 THEN 10&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='rank of application id' datatype='integer' name='[Calculation_544372654718648322]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(COUNT([Application Id]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='funnel left' datatype='integer' name='[Calculation_544372654718812163]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Calculation_544372654718648322]&#13;&#10;    WHEN 1 THEN -100&#13;&#10;    WHEN 2 THEN -80&#13;&#10;    WHEN 3 THEN -60&#13;&#10;    WHEN 4 THEN -40&#13;&#10;    WHEN 5 THEN -20&#13;&#10;    WHEN 6 THEN -10&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='funnel right' datatype='integer' name='[Calculation_544372654718959620]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Calculation_544372654718648322]&#13;&#10;    WHEN 1 THEN 100&#13;&#10;    WHEN 2 THEN 80&#13;&#10;    WHEN 3 THEN 60&#13;&#10;    WHEN 4 THEN 40&#13;&#10;    WHEN 5 THEN 20&#13;&#10;    WHEN 6 THEN 10&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='funnel drop' datatype='real' name='[Calculation_544372654719553541]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL(LOOKUP([Calculation_544372654706106368], -1)) THEN&#13;&#10;    0&#13;&#10;ELSE&#13;&#10;    (&#13;&#10;        LOOKUP([Calculation_544372654706106368], -1)&#13;&#10;        - [Calculation_544372654706106368]&#13;&#10;    ) * 100&#13;&#10;    /&#13;&#10;    LOOKUP([Calculation_544372654706106368], -1)&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='stage % of total' datatype='real' name='[Calculation_544372654720888838]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Application Id])*100&#13;&#10;/&#13;&#10;WINDOW_MAX(COUNT([Application Id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='date in range' datatype='boolean' name='[Calculation_544372654732791817]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Application Date] &gt;= [Parameters].[Defect Rate Parameter]&#13;&#10;AND&#13;&#10;[Application Date] &lt;= [Parameters].[Start Date (copy)]' />
      </column>
      <column caption='Avg loan amt per application' datatype='real' name='[Calculation_544372654754127886]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Loan Amount]) / ([Calculation_544372654952869903])' />
      </column>
      <column caption='Approved Applications' datatype='integer' name='[Calculation_544372654952869903]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Status] = &quot;Approved&quot; THEN [Application Id] END&#13;&#10;)' />
      </column>
      <column caption='Defect Rate Kpi' datatype='real' name='[Calculation_544372654954000400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF  [Calculation_544372654732791817] and [Status]=&apos;Defect&apos;&#13;&#10;    THEN 1 ELSE 0 &#13;&#10;    END&#13;&#10;)*100' />
      </column>
      <column caption='Denial Ratio KPI' datatype='real' name='[Calculation_544372654955466769]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_544372654732791817] and [Status]=&apos;Denied&apos;&#13;&#10;    THEN 1 ELSE 0 &#13;&#10;    END&#13;&#10;)*100' />
      </column>
      <column caption='compliance score KPI' datatype='real' name='[Calculation_544372654957162514]' role='measure' type='quantitative'>
